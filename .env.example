# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Turso database — run: turso db create lingua && turso db show lingua --url
TURSO_DATABASE_URL=libsql://your-database.turso.io

# Turso auth token — run: turso db tokens create lingua
TURSO_AUTH_TOKEN=

# Groq API key for transcription — https://console.groq.com/keys
GROQ_API_KEY=
